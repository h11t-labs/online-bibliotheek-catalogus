# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# Alternatively export TF_VAR_railway_token / RAILWAY_TOKEN instead of putting it here.

# Required — Railway account or team API token (dashboard → Settings → Tokens)
railway_token = ""

# Optional overrides (defaults shown)
# project_name = "online-bibliotheek-catalogus"
# service_name = "web"
# github_repo  = "mymix/online-bibliotheek-catalogus"
# image_tag    = "0.1"
# subdomain    = "online-bibliotheek-catalogus"

# Optional — enables the NYT bestseller lists
# nyt_api_key  = ""

# In-app refresh scheduler (hours; 0 = off)
# sync_hours   = "24"
# lists_hours  = "168"
