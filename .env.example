# Copy to `.env` and fill in. Loaded automatically by the `obc` CLI.

# New York Times Best Sellers — free key from https://developer.nytimes.com
# (create an app, enable the "Books API"). Without it the NYT list provider skips.
NYT_API_KEY=

# Optional: point the web UI / tools at a different SQLite catalog file.
# OBC_DB=data/catalog.db
